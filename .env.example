# Base de données PostgreSQL
DB_PASSWORD=changeme_db_password

# JWT — générer avec : openssl rand -hex 32
SECRET_KEY=changeme_secret_key_32_chars_minimum

# Admin initial (créé en DB au premier démarrage si aucun user n'existe)
ADMIN_USERNAME=thomas
# Générer le hash : python3 -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('ton_mdp'))"
ADMIN_PASSWORD_HASH=$2b$12$REMPLACER_PAR_LE_VRAI_HASH

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# SMTP — envoi des liens d'invitation par email (optionnel)
# Laisser vide pour désactiver ; sinon renseigner tous les champs
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=moncompte@gmail.com
SMTP_PASSWORD=app_password_ici
SMTP_FROM=moncompte@gmail.com
APP_BASE_URL=https://mesplantes.example.com
